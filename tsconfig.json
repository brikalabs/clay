{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2024", "ESNext"],
    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": "./src",
    "noImplicitOverride": true,
    "ignoreDeprecations": "6.0",
    "types": ["bun-types"]
  },
  "include": ["src/**/*", "src/**/*.json"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx", "**/*.stories.tsx"]
}
