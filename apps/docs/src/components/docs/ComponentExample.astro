---
import CodeSource from './CodeSource.astro';

/**
 * Live demo + collapsible code block.
 *
 * Layout:
 *   ┌── header (title + code toggle) ──────────────────────────┐
 *   │  01 ─── Title                              [<> Code]      │
 *   │  Optional description                                     │
 *   ├───────────────────────────────────────────────────────────┤
 *   │                                                           │
 *   │   [preview]                                               │
 *   │                                                           │
 *   ├─── only when expanded ────────────────────────────────────┤
 *   │  [syntax-highlighted code]                                │
 *   └───────────────────────────────────────────────────────────┘
 */

interface Props {
  readonly code: string;
  readonly lang?: 'tsx' | 'ts' | 'jsx' | 'js' | 'bash' | 'css' | 'html';
  readonly title?: string;
  readonly description?: string;
  readonly index?: number;
  readonly anchorId?: string;
  /** When set, renders a "view this example's source on GitHub" link in the header. */
  readonly sourceUrl?: string;
}

const { code, lang = 'tsx', title, description, index, anchorId, sourceUrl } = Astro.props;

function pad(n: number) {
  return n.toString().padStart(2, '0');
}
---

<div
  class="component-example not-prose scroll-mt-24 overflow-hidden rounded-lg border border-clay-hairline bg-clay-elevated"
  data-component-example
>
  {title ? (
    <div class="flex items-start justify-between gap-4 border-clay-hairline border-b px-4 py-3">
      <div class="min-w-0 flex-1">
        <div class="mb-0.5 flex items-baseline gap-2 font-mono text-xs text-clay-subtle">
          {index !== undefined && (
            <>
              <span class="tabular-nums text-clay-inactive" aria-hidden="true">{pad(index)}</span>
              <span class="hairline w-4 shrink-0" aria-hidden="true" />
            </>
          )}
          <h3 id={anchorId} class="scroll-mt-24 font-medium text-clay-strong text-xs">{title}</h3>
        </div>
        {description && (
          <p class="mt-1 max-w-2xl text-clay-default text-sm leading-relaxed">{description}</p>
        )}
      </div>
      <div class="flex shrink-0 items-center gap-2">
        {sourceUrl && (
          <a
            href={sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-7 items-center gap-1.5 rounded-md border border-clay-hairline bg-clay-base px-2.5 font-mono text-xs text-clay-subtle transition-all hover:border-clay-strong hover:bg-clay-elevated hover:text-clay-default"
            aria-label="View this example's source on GitHub"
            title="View source on GitHub"
          >
            <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="shrink-0">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
            </svg>
            <span>GitHub</span>
          </a>
        )}
        <button
          type="button"
          class="code-toggle-btn inline-flex h-7 items-center gap-1.5 rounded-md border border-clay-hairline bg-clay-base px-2.5 font-mono text-xs text-clay-subtle transition-all hover:border-clay-strong hover:bg-clay-elevated hover:text-clay-default"
          aria-expanded="false"
          aria-label="Show code"
        >
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0">
            <polyline points="16 18 22 12 16 6"/>
            <polyline points="8 6 2 12 8 18"/>
          </svg>
          <span class="code-toggle-label">Code</span>
        </button>
      </div>
    </div>
  ) : (
    <div class="flex items-center justify-between gap-3 border-clay-hairline border-b px-4 py-2">
      <span class="font-mono text-[0.6875rem] text-clay-inactive tracking-wide uppercase">Preview</span>
      <div class="flex items-center gap-2">
        {sourceUrl && (
          <a
            href={sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-6 items-center gap-1.5 rounded border border-clay-hairline bg-clay-base px-2 font-mono text-[0.6875rem] text-clay-subtle transition-all hover:border-clay-strong hover:text-clay-default"
            aria-label="View this example's source on GitHub"
            title="View source on GitHub"
          >
            <svg width="11" height="11" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
            </svg>
            <span>GitHub</span>
          </a>
        )}
        <button
          type="button"
          class="code-toggle-btn inline-flex h-6 items-center gap-1.5 rounded border border-clay-hairline bg-clay-base px-2 font-mono text-[0.6875rem] text-clay-subtle transition-all hover:border-clay-strong hover:text-clay-default"
          aria-expanded="false"
          aria-label="Show code"
        >
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="16 18 22 12 16 6"/>
            <polyline points="8 6 2 12 8 18"/>
          </svg>
          Code
        </button>
      </div>
    </div>
  )}

  <div class="preview-grid relative flex min-h-[11rem] items-center justify-center px-6 py-10">
    <slot />
  </div>

  <div class="code-section hidden border-clay-hairline border-t">
    <CodeSource code={code} lang={lang} variant="compact" />
  </div>
</div>

<script>
  for (const example of document.querySelectorAll<HTMLElement>('[data-component-example]')) {
    const btn = example.querySelector<HTMLButtonElement>('.code-toggle-btn');
    const codeSection = example.querySelector<HTMLElement>('.code-section');
    const label = btn?.querySelector<HTMLElement>('.code-toggle-label');
    if (!btn || !codeSection) continue;

    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isOpen));
      codeSection.classList.toggle('hidden', isOpen);
      btn.setAttribute('aria-label', isOpen ? 'Show code' : 'Hide code');
      if (label) label.textContent = isOpen ? 'Code' : 'Hide';
    });
  }
</script>
