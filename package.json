{
  "name": "@brika/clay",
  "version": "0.1.0",
  "description": "Clay — Brika's React component library, token system, and first-party themes",
  "type": "module",
  "license": "MIT",
  "author": "BRIKA Team",
  "homepage": "https://github.com/brikalabs/brika/tree/main/packages/clay#readme",
  "bugs": {
    "url": "https://github.com/brikalabs/brika/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brikalabs/brika.git",
    "directory": "packages/clay"
  },
  "keywords": [
    "brika",
    "clay",
    "react",
    "components",
    "design-system",
    "tailwind",
    "tailwindcss",
    "themes"
  ],
  "sideEffects": [
    "**/*.css",
    "**/components/*/tokens.ts",
    "**/components/*/tokens.js",
    "**/tokens/components.ts",
    "**/tokens/components.js",
    "**/tokens/orphan-components.ts",
    "**/tokens/orphan-components.js"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./assets/*": "./src/assets/*",
    "./components/*": "./src/components/*/index.ts",
    "./primitives": "./src/primitives/index.ts",
    "./primitives/*": "./src/primitives/*.ts",
    "./styles": "./src/styles/clay.css",
    "./styles/*": "./src/styles/*.css",
    "./tailwind": "./src/tailwind.ts",
    "./themes": "./src/themes/index.ts",
    "./themes/registry": "./src/themes/registry.ts",
    "./tokens": "./src/tokens/index.ts"
  },
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --noEmit false",
    "dev": "tsup --watch",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "radix-ui": "^1.4.3",
    "recharts": "^3.7.0",
    "shiki": "^3.23.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.5"
  }
}
