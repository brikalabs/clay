  "geometry": {
    "radius": "0px",
    "fontSans": "\"JetBrains Mono\", ui-monospace, SFMono-Regular, monospace",
    "fontMono": "\"JetBrains Mono\", ui-monospace, SFMono-Regular, monospace"
