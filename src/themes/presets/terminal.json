{
  "id": "terminal",
  "name": "Terminal",
  "description": "Mono UI, dashed dividers, zero radius. Amber CRT in light, phosphor green in dark — vintage terminal energy.",
  "accentSwatches": ["#b85800", "#00ff88", "#d68a1a", "#a51a1a"],
  "colors": {
    "light": {
      "background": "#fff5dc",
      "foreground": "#2d1d05",
      "card": "#fffbe8",
      "card-foreground": "#2d1d05",
      "popover": "#fffbe8",
      "popover-foreground": "#2d1d05",
      "primary": "#b85800",
      "primary-foreground": "#fff5dc",
      "secondary": "#f5e8c4",
      "secondary-foreground": "#2d1d05",
      "muted": "#f5ead0",
      "muted-foreground": "#6b4f1f",
      "accent": "#d68a1a",
      "accent-foreground": "#2d1d05",
      "border": "#9c6b1f",
      "input": "#9c6b1f",
      "ring": "#b85800",
      "success": "#7a8c1f",
      "success-foreground": "#fff5dc",
      "warning": "#b85800",
      "warning-foreground": "#fff5dc",
      "info": "#5a4a8c",
      "info-foreground": "#fff5dc",
      "destructive": "#a51a1a",
      "destructive-foreground": "#fff5dc"
    },
    "dark": {
      "background": "#0a0f0a",
      "foreground": "#00ff88",
      "card": "#0f1a0f",
      "card-foreground": "#00ff88",
      "popover": "#0f1a0f",
      "popover-foreground": "#00ff88",
      "primary": "#00ff88",
      "primary-foreground": "#0a0f0a",
      "secondary": "#142214",
      "secondary-foreground": "#00ff88",
      "muted": "#142214",
      "muted-foreground": "#5fbf7f",
      "accent": "#00d9ff",
      "accent-foreground": "#0a0f0a",
      "border": "#00ff88",
      "input": "#00ff88",
      "ring": "#00ff88",
      "success": "#00ff88",
      "success-foreground": "#0a0f0a",
      "warning": "#ffaf00",
      "warning-foreground": "#0a0f0a",
      "info": "#00d9ff",
      "info-foreground": "#0a0f0a",
      "destructive": "#ff5f87",
      "destructive-foreground": "#0a0f0a"
    }
  },
  "geometry": {
    "radius": "0px",
    "fontSans": "\"JetBrains Mono\", \"Fira Code\", ui-monospace, SFMono-Regular, monospace",
    "fontMono": "\"JetBrains Mono\", \"Fira Code\", ui-monospace, SFMono-Regular, monospace"
  },
  "borders": {
    "width": "1px",
    "style": "solid"
  },
  "motion": {
    "duration": "80ms",
    "easing": "steps(4, end)"
  },
  "focus": {
    "width": "1px",
    "offset": "0px"
  },
  "components": {
    "button": {
      "letterSpacing": "0.04em",
      "textTransform": "uppercase",
      "fontWeight": "500"
    },
    "card": {
      "shadow": "none",
      "borderWidth": "1px",
      "borderStyle": "dashed"
    },
    "dialog": {
      "shadow": "none",
      "borderStyle": "solid"
    },
    "separator": {
      "style": "dashed",
      "width": "1px"
    },
    "input": {
      "borderStyle": "solid"
    },
    "tooltip": {
      "letterSpacing": "0.05em",
      "textTransform": "uppercase"
    },
    "badge": {
      "letterSpacing": "0.06em",
      "textTransform": "uppercase",
      "fontWeight": "500"
    },
    "label": {
      "letterSpacing": "0.04em",
      "textTransform": "uppercase",
      "fontWeight": "500"
    }
  },
  "effects": ["scanlines", "glow"]
}
