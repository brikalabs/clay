  "geometry": {
    "radius": "1.25rem",
    "fontSans": "\"Inter\", ui-sans-serif, system-ui, sans-serif",
    "fontMono": "\"Iowan Old Style\", ui-monospace, SFMono-Regular, monospace"
  },
  "borders": {
    "width": "1px",
    "style": "solid"
  },
  "motion": {
    "duration": "320ms",
    "easing": "cubic-bezier(0.22, 1, 0.36, 1)"
  },
  "focus": {
    "width": "2px",
    "offset": "3px"
  },
  "components": {
    "button": {
      "fontFamily": "\"Inter\", ui-sans-serif, system-ui, sans-serif",
      "fontWeight": "500",
      "letterSpacing": "0.01em",
      "textTransform": "none"
    },
    "card": {
      "shadow": "var(--shadow-overlay)"
    },
    "label": {
      "fontFamily": "\"Instrument Serif\", \"Iowan Old Style\", Georgia, serif",
      "fontWeight": "400",
      "letterSpacing": "0.01em",
      "textTransform": "none"
    }
  },
  "effects": ["paper"]
