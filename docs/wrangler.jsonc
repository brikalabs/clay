{
  "$schema": "https://json.schemastore.org/wrangler.json",
  // Cloudflare Workers (Static Assets) config for the Clay docs site.
  // `astro build` writes static output to `./dist`, which Workers serves.
  // Day-to-day deploys: `bun run clay:deploy` from the repo root.
  "name": "brika-clay",
  "compatibility_date": "2025-04-01",
  "assets": {
    "directory": "./dist"
  }
}
