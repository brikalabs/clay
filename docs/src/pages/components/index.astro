---
import MainLayout from '~/layouts/MainLayout.astro';
import { COMPONENT_GROUPS, COMPONENTS, componentsInGroup } from '~/lib/component-registry';

function pad(n: number): string {
  return n.toString().padStart(2, '0');
}

let runningIndex = 0;
---

<MainLayout
  title="Components — Clay"
  description="Every Clay component in one place. Click through to full docs and live demos."
>
  <!-- HERO -->
  <section class="border-clay-hairline border-b">
    <div class="mx-auto max-w-6xl px-6 pt-20 pb-12 md:px-12">
      <div class="mb-6 flex items-center gap-3 mono-tag-tight">
        <span class="hairline w-8"></span>
        <span class="text-clay-strong">Library</span>
        <span class="hairline flex-1"></span>
        <span class="text-clay-inactive">{COMPONENTS.length} primitives</span>
      </div>
      <h1 class="font-display text-clay-strong text-6xl leading-[1.02] md:text-7xl">
        Every Clay <span class="font-display-italic text-clay-subtle">component.</span>
      </h1>
      <p class="mt-6 max-w-xl text-clay-default text-lg leading-relaxed">
        Thirty-seven primitives, grouped by intent. Each page renders live demos against the
        active theme — pick a theme above and the gallery follows.
      </p>
    </div>
  </section>

  <!-- GROUP SECTIONS -->
  <div class="mx-auto max-w-6xl px-6 py-12 md:px-12">
    {
      COMPONENT_GROUPS.map((group, groupIndex) => {
        const items = componentsInGroup(group);
        if (items.length === 0) return null;
        return (
          <section class="mb-16 last:mb-0">
            <div class="numbered-rule mb-8">
              <span class="num">{pad(groupIndex + 1)}</span>
              <span class="label">{group}</span>
              <span class="spacer hairline" />
              <span class="text-clay-inactive">
                {pad(items.length)} {items.length === 1 ? 'component' : 'components'}
              </span>
            </div>

            <div class="grid grid-cols-1 gap-px overflow-hidden rounded-lg border border-clay-hairline bg-clay-hairline sm:grid-cols-2 lg:grid-cols-3">
              {items.map((component) => {
                runningIndex += 1;
                const num = pad(runningIndex);
                return (
                  <a
                    href={`/components/${component.slug}`}
                    class="group relative flex flex-col gap-3 bg-clay-elevated p-5 transition-colors hover:bg-clay-base"
                  >
                    <div class="flex items-center gap-2">
                      <span class="font-medium font-mono text-[0.625rem] text-clay-inactive uppercase tracking-[0.12em]">
                        {num}
                      </span>
                      <span class="block h-px w-6 bg-clay-hairline" />
                      <span class="font-mono text-[0.625rem] text-clay-inactive uppercase tracking-[0.12em]">
                        {component.slug}
                      </span>
                    </div>
                    <p
                      class="text-clay-strong text-2xl leading-tight"
                      style={{
                        fontFamily:
                          '"Instrument Serif", "Iowan Old Style", Georgia, serif',
                        fontStyle: 'italic',
                        letterSpacing: '-0.022em',
                      }}
                    >
                      {component.name}
                    </p>
                    <p class="line-clamp-3 text-clay-subtle text-xs leading-snug">
                      {component.description}
                    </p>
                    <span
                      aria-hidden="true"
                      class="absolute right-4 bottom-4 font-mono text-clay-inactive text-sm opacity-0 transition-opacity group-hover:opacity-100"
                    >
                      →
                    </span>
                  </a>
                );
              })}
            </div>
          </section>
        );
      })
    }
  </div>
</MainLayout>
