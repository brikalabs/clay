---
import { Code } from 'astro:components';

/**
 * Single source-of-truth code block for the docs site.
 *
 * Renders Astro's bundled Shiki via `<Code>`. The wrapper owns the
 * background, border, and radius so the header strip and code body
 * share one continuous surface — no double-box effect when Shiki's own
 * background colour differs from the docs chrome.
 *
 * Two variants:
 *  - `default` (stand-alone) wraps in a rounded card with a header
 *    showing language + filename + copy button.
 *  - `compact` is meant to slot inside another card (e.g. ComponentExample).
 *    No outer rounding, no border, no margin. Copy button floats over
 *    the top-right corner on hover.
 */

interface Props {
  readonly code: string;
  readonly lang?: 'tsx' | 'ts' | 'jsx' | 'js' | 'bash' | 'css' | 'html' | 'json';
  readonly filename?: string;
  readonly variant?: 'default' | 'compact';
}

const { code, lang = 'tsx', filename, variant = 'default' } = Astro.props;
const isDefault = variant === 'default';
const lineCount = code
  .split('\n')
  .filter((line, index, arr) => index < arr.length - 1 || line.length > 0).length;
---

{
  isDefault ? (
    <div class="clay-code-source not-prose group relative my-3 overflow-hidden rounded-lg border border-clay-hairline bg-clay-elevated">
      <div class="flex items-center justify-between gap-3 border-clay-hairline border-b px-3 py-1.5 font-mono text-xs">
        <div class="flex min-w-0 flex-1 items-center gap-2">
          <span class="rounded bg-secondary px-1.5 py-0.5 font-medium text-[0.625rem] text-secondary-foreground uppercase tracking-wider">
            {lang}
          </span>
          {filename && <span class="min-w-0 truncate text-clay-default">{filename}</span>}
          <span class="text-[0.625rem] text-clay-inactive">
            {`${lineCount} ${lineCount === 1 ? 'line' : 'lines'}`}
          </span>
        </div>
        <button
          type="button"
          class="copy-button inline-flex size-6 shrink-0 items-center justify-center rounded text-clay-subtle transition-colors hover:bg-clay-control hover:text-clay-default"
          data-copy-text={code}
          aria-label="Copy code to clipboard"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="13"
            height="13"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="copy-icon"
            aria-hidden="true"
          >
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
          </svg>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="13"
            height="13"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="check-icon hidden text-clay-brand"
            aria-hidden="true"
          >
            <polyline points="20 6 9 17 4 12" />
          </svg>
        </button>
      </div>
      <div class="overflow-x-auto">
        <Code
          code={code}
          lang={lang}
          themes={{ light: 'catppuccin-latte', dark: 'catppuccin-mocha' }}
          defaultColor={false}
        />
      </div>
    </div>
  ) : (
    <div class="clay-code-source group relative bg-clay-elevated">
      <div class="overflow-x-auto">
        <Code
          code={code}
          lang={lang}
          themes={{ light: 'catppuccin-latte', dark: 'catppuccin-mocha' }}
          defaultColor={false}
        />
      </div>
      <button
        type="button"
        class="copy-button absolute top-1.5 right-1.5 inline-flex size-6 shrink-0 items-center justify-center rounded bg-clay-elevated text-clay-subtle opacity-0 transition-all hover:bg-clay-control hover:text-clay-default group-hover:opacity-100"
        data-copy-text={code}
        aria-label="Copy code to clipboard"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="13"
          height="13"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="copy-icon"
          aria-hidden="true"
        >
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
        </svg>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="13"
          height="13"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="check-icon hidden text-clay-brand"
          aria-hidden="true"
        >
          <polyline points="20 6 9 17 4 12" />
        </svg>
      </button>
    </div>
  )
}

<script>
  for (const btn of document.querySelectorAll<HTMLButtonElement>('.copy-button[data-copy-text]')) {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copyText ?? '';
      const copy = btn.querySelector<SVGElement>('.copy-icon');
      const check = btn.querySelector<SVGElement>('.check-icon');
      try {
        await navigator.clipboard.writeText(text);
        if (copy && check) {
          copy.classList.add('hidden');
          check.classList.remove('hidden');
          setTimeout(() => {
            copy.classList.remove('hidden');
            check.classList.add('hidden');
          }, 1400);
        }
      } catch {
        // Clipboard blocked — keep button state.
      }
    });
  }
</script>
