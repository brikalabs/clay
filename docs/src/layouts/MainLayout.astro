---
import { CommandPalette } from '~/components/CommandPalette.tsx';
import Footer from '~/components/Footer.astro';
import Header from '~/components/Header.astro';
import { SidebarNav } from '~/components/SidebarNav.tsx';
import BaseLayout from './BaseLayout.astro';

interface Props {
  readonly title: string;
  readonly description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;
---

<BaseLayout title={title} description={description}>
  <div class="isolate">
    <SidebarNav currentPath={currentPath} client:load />
    <div id="main-content" class="main-content flex min-h-screen flex-col transition-[margin] duration-300">
      <Header />
      <main class="flex grow flex-col">
        <slot />
      </main>
      <Footer />
    </div>
    <CommandPalette client:only="react" />
  </div>
</BaseLayout>

<style is:global>
  @media (min-width: 768px) {
    body:has(aside[data-sidebar-open="true"]) .main-content {
      margin-left: 304px; /* 48px rail + 256px panel */
    }
    body:has(aside[data-sidebar-open="false"]) .main-content {
      margin-left: 48px;
    }
  }
  @media (max-width: 767px) {
    .main-content {
      margin-left: 48px;
    }
  }
</style>
