---
import { Toaster } from '@brika/clay/components/toast';
import { CopyPageMenu } from '~/components/docs/CopyPageMenu.tsx';
import { OnThisPage } from '~/components/OnThisPage.tsx';
import { repoTreeUrl } from '~/lib/github';
import DocLayout from './DocLayout.astro';

interface Props {
  readonly frontmatter: {
    readonly title: string;
    readonly description?: string;
    readonly sourceFile?: string;
    readonly group?: string;
  };
}

const { frontmatter } = Astro.props;

if (!Astro.site) {
  throw new Error('astro.config.site must be set for MdxDocLayout');
}
const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const pageUrl = new URL(pathname, Astro.site).href;
const markdownUrl = `${pathname}.md`;

const componentSourceUrl = frontmatter.sourceFile
  ? repoTreeUrl(`packages/clay/src/${frontmatter.sourceFile}`)
  : undefined;
---

<DocLayout title={frontmatter.title} description={frontmatter.description} hasRail>
  <header class="not-prose mb-12">
    <div class="mb-6 flex items-center gap-3 mono-tag-tight">
      <span class="hairline w-8"></span>
      <span class="text-clay-strong">{frontmatter.group ?? 'Documentation'}</span>
      <span class="hairline flex-1"></span>
    </div>

    <div class="flex items-start justify-between gap-6">
      <div class="flex-1">
        <h1 class="font-display text-clay-strong text-5xl leading-[1.02] md:text-6xl">
          {frontmatter.title}
        </h1>
        {
          frontmatter.description && (
            <p class="mt-5 max-w-2xl text-clay-default text-lg leading-relaxed">
              {frontmatter.description}
            </p>
          )
        }
        {
          componentSourceUrl && (
            <div class="mt-6 flex flex-wrap items-center gap-3">
              <a
                href={componentSourceUrl}
                rel="noopener noreferrer"
                class="inline-flex h-8 items-center gap-2 rounded-md border border-clay-hairline bg-clay-elevated px-3 font-medium text-clay-default text-xs transition-colors hover:border-clay-strong hover:bg-clay-control"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  width="13"
                  height="13"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M12 2C6.475 2 2 6.475 2 12c0 4.425 2.863 8.166 6.839 9.489.5.092.683-.217.683-.483 0-.237-.008-.867-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.004.071 1.532 1.031 1.532 1.031.892 1.529 2.341 1.087 2.911.832.091-.647.35-1.087.636-1.337-2.22-.252-4.555-1.11-4.555-4.942 0-1.091.39-1.984 1.03-2.683-.103-.253-.447-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.837c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .269.18.58.688.481C19.138 20.163 22 16.423 22 12c0-5.525-4.475-10-10-10z" />
                </svg>
                <span>Source</span>
              </a>
            </div>
          )
        }
      </div>
      <div class="shrink-0 pt-1">
        <CopyPageMenu pageUrl={pageUrl} markdownUrl={markdownUrl} client:load />
      </div>
    </div>
  </header>

  <slot />

  <OnThisPage slot="rail" client:only="react" />
  <Toaster client:only="react" />
</DocLayout>
