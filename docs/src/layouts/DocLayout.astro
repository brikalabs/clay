---
import MainLayout from './MainLayout.astro';

interface Props {
  readonly title: string;
  readonly description?: string;
  /** When true, render a right-rail column with a `rail` named slot. */
  readonly hasRail?: boolean;
}

const { title, description, hasRail = false } = Astro.props;
---

<MainLayout title={title} description={description}>
  {
    hasRail ? (
      <div class="mx-auto grid w-full max-w-6xl grid-cols-1 gap-10 px-6 py-10 md:px-10 lg:grid-cols-[minmax(0,1fr)_14rem]">
        <article
          data-doc-article
          class="clay-prose prose prose-slate max-w-none lg:max-w-3xl"
        >
          <slot />
        </article>
        <aside class="hidden lg:block">
          <div class="sticky top-20">
            <slot name="rail" />
          </div>
        </aside>
      </div>
    ) : (
      <div class="mx-auto w-full max-w-4xl px-6 py-10 md:px-10">
        <article data-doc-article class="clay-prose prose prose-slate max-w-none">
          <slot />
        </article>
      </div>
    )
  }
</MainLayout>
