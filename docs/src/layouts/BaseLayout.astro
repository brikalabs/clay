---
import faviconDark from '@brika/clay/assets/clay-ui-flat.svg?url';
import faviconLight from '@brika/clay/assets/clay-ui-flat-dark.svg?url';
import { renderThemeStyleSheet } from '@brika/clay/themes';
import { builtInThemes } from '@brika/clay/themes/registry';
import '~/styles/global.css';

interface Props {
  readonly title: string;
  readonly description?: string;
}

const { title, description } = Astro.props;

if (!Astro.site) {
  throw new Error('astro.config.site must be set for canonical / OG meta');
}

const SITE_NAME = 'Clay';
const SITE_TAGLINE = "Brika's React component library, token system, and first-party themes.";

// Append " — Clay" to titles that don't already mention the brand, so search
// results and tab strips read consistently across pages.
const fullTitle = title.includes(SITE_NAME) ? title : `${title} — ${SITE_NAME}`;

const canonicalUrl = new URL(Astro.url.pathname.replace(/\/+$/, '') || '/', Astro.site).href;
const ogImageUrl = new URL('/og-image.svg', Astro.site).href;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  description: SITE_TAGLINE,
  url: Astro.site.href,
};

// Pre-render every theme's CSS + effects at SSR time. The map gets
// inlined in `<head>` so the synchronous boot script below can pick the
// saved theme out of localStorage and emit the matching `<style>` tag
// (and `data-effects` attribute) BEFORE first paint — no flash, no
// extra fetch. The `default` theme is included so first-time visitors
// (no localStorage) get Clay's branded palette instead of the package's
// neutral registry fallback.
const THEME_DATA = Object.fromEntries(
  builtInThemes.map((t) => [
    t.id,
    {
      css: renderThemeStyleSheet(t),
      effects: (t.effects ?? []).map((name) => `fx-${name}`).join(' '),
    },
  ])
);
const THEME_DATA_JSON = JSON.stringify(THEME_DATA);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}

    <link rel="canonical" href={canonicalUrl} />

    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#d9d0c2" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#2b2b2b" />

    <link rel="icon" type="image/svg+xml" href={faviconLight} media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href={faviconDark} media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" href={ogImageUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content={`${SITE_NAME} — ${SITE_TAGLINE}`} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={`${SITE_NAME} — ${SITE_TAGLINE}`} />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
    <script is:inline define:vars={{ THEME_DATA_JSON }}>
      (() => {
        // Boot script — runs synchronously in <head> before first paint.
        // 1. Reads `data-mode` (light/dark) from localStorage / OS pref.
        // 2. Reads `data-theme` (preset id) from localStorage and injects
        //    the pre-rendered `<style id="clay-theme">` so the page paints
        //    with the chosen theme on first frame — no flash, no extra
        //    network round trip.
        // 3. Writes `data-effects` so theme effects (scanlines, glow, …)
        //    are active before paint too.
        try {
          const root = document.documentElement;

          const MODE_KEY = 'clay-mode';
          const storedMode = localStorage.getItem(MODE_KEY);
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const mode =
            storedMode === 'light' || storedMode === 'dark'
              ? storedMode
              : prefersDark
                ? 'dark'
                : 'light';
          root.dataset.mode = mode;

          const THEME_KEY = 'clay-theme';
          const themeMap = JSON.parse(THEME_DATA_JSON);
          const storedTheme = localStorage.getItem(THEME_KEY);
          const themeId = storedTheme && themeMap[storedTheme] ? storedTheme : 'default';
          const entry = themeMap[themeId];
          if (!entry) {
            return;
          }
          root.dataset.theme = themeId;
          // Strip any prior `fx-*` classes before adding the new ones —
          // switching themes must clear effects from the previous one.
          for (const cls of Array.from(root.classList)) {
            if (cls.startsWith('fx-')) {
              root.classList.remove(cls);
            }
          }
          if (entry.effects) {
            for (const cls of entry.effects.split(' ')) {
              root.classList.add(cls);
            }
          }
          const tag = document.createElement('style');
          tag.id = 'clay-theme';
          tag.textContent = entry.css;
          document.head.appendChild(tag);
        } catch {
          /* localStorage / matchMedia unavailable — let CSS defaults render. */
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
