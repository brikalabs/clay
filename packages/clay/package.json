{
  "name": "@brika/clay",
  "version": "0.0.1",
  "description": "Clay, Brika Labs' React component library, token system, and first-party themes",
  "type": "module",
  "license": "MIT",
  "author": "BRIKA Team",
  "homepage": "https://github.com/brikalabs/clay#readme",
  "bugs": {
    "url": "https://github.com/brikalabs/clay/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brikalabs/clay.git",
    "directory": "packages/clay"
  },
  "keywords": [
    "brika",
    "clay",
    "react",
    "components",
    "design-system",
    "tailwind",
    "tailwindcss",
    "themes"
  ],
  "sideEffects": [
    "**/*.css",
    "**/components/*/tokens.ts",
    "**/components/*/tokens.js",
    "**/components/register.ts",
    "**/components/register.js"
  ],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./assets/*": "../../assets/*",
    "./components/*": "./src/components/*/index.ts",
    "./primitives": "./src/primitives/index.ts",
    "./primitives/*": "./src/primitives/*.ts",
    "./styles": "./src/styles/clay.css",
    "./styles/*": "./src/styles/*.css",
    "./tailwind": "./src/tailwind.ts",
    "./themes": "./src/themes/index.ts",
    "./themes/registry": "./src/themes/registry.ts",
    "./tokens": "./src/tokens/index.ts"
  },
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
      "./assets/*": "./dist/assets/*",
      "./components/*": {
        "types": "./dist/components/*/index.d.ts",
        "import": "./dist/components/*/index.js"
      },
      "./primitives": {
        "types": "./dist/primitives/index.d.ts",
        "import": "./dist/primitives/index.js"
      },
      "./primitives/*": {
        "types": "./dist/primitives/*.d.ts",
        "import": "./dist/primitives/*.js"
      },
      "./styles": "./dist/styles/clay.css",
      "./styles/*": "./dist/styles/*.css",
      "./tailwind": {
        "types": "./dist/tailwind.d.ts",
        "import": "./dist/tailwind.js"
      },
      "./themes": {
        "types": "./dist/themes/index.d.ts",
        "import": "./dist/themes/index.js"
      },
      "./themes/registry": {
        "types": "./dist/themes/registry.d.ts",
        "import": "./dist/themes/registry.js"
      },
      "./tokens": {
        "types": "./dist/tokens/index.d.ts",
        "import": "./dist/tokens/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --noEmit false",
    "dev": "tsup --watch",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "bench": "bun src/__tests__/tailwind-plugin.bench.ts && bun src/themes/__tests__/themes.bench.ts && bun src/tokens/__tests__/tokens.bench.ts && bun src/primitives/__tests__/cn.bench.ts",
    "bench:tailwind": "bun src/__tests__/tailwind-plugin.bench.ts",
    "bench:themes": "bun src/themes/__tests__/themes.bench.ts",
    "bench:tokens": "bun src/tokens/__tests__/tokens.bench.ts",
    "bench:cn": "bun src/primitives/__tests__/cn.bench.ts",
    "prepack": "bun run ./scripts/prepack.ts pre",
    "postpack": "bun run ./scripts/prepack.ts post",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.575.0",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.10.0",
    "recharts": "^3.7.0",
    "shiki": "^3.23.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "latest",
    "bun-types": "latest",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.5",
    "typescript": "^6.0.2"
  }
}
